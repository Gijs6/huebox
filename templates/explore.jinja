{% extends "base.jinja" %}

{% block title %}Explore{% endblock %}

{% block main %}
    <div class="page-header">
        <h1 class="page-header__title">Explore</h1>
        {% if palettes %}<span class="page-header__count">{{ palettes | length }} palette{{ 's' if palettes | length != 1 }}</span>{% endif %}
    </div>

    {% if palettes %}
        <div class="palette-grid">
            {% for p in palettes %}
                <article class="palette-card">
                    <a href="{{ url_for('view_palette', id=p.id) }}"
                       class="palette-card__strip-link">
                        <div class="palette-card__strip">
                            {% for color in p.colors %}<div class="palette-card__swatch" style="--color: {{ color.hex_value }}"></div>{% endfor %}
                        </div>
                    </a>
                    <div class="palette-card__body">
                        <a href="{{ url_for('view_palette', id=p.id) }}"
                           class="palette-card__name">{{ p.name }}</a>
                        <div class="palette-card__meta">
                            <span class="palette-card__author">
                                {% if p.owner.avatar_url %}
                                    <img src="{{ p.owner.avatar_url }}"
                                         alt="{{ p.owner.login }}"
                                         class="palette-card__avatar">
                                {% endif %}
                                {{ p.owner.login }}
                            </span>
                            <span>{{ p.colors | length }} color{{ 's' if p.colors | length != 1 }}</span>
                        </div>

                        <div class="palette-card__footer">
                            {% if current_user and current_user.id != p.user_id %}
                                <button type="button"
                                        class="btn btn--ghost btn--sm"
                                        hx-post="{{ url_for('fork_palette', id=p.id) }}"
                                        hx-swap="none">Fork</button>
                            {% endif %}

                            {% if current_user and current_user.id != p.user_id %}
                                <button type="button"
                                        class="like-btn like-btn--sm {% if p.id in liked_ids %}like-btn--liked{% endif %}"
                                        hx-post="{{ url_for('toggle_like', id=p.id) }}"
                                        hx-swap="none">
                                    <i class="fa-solid fa-heart"></i> {{ p.like_count }}
                                </button>
                            {% else %}
                                <span class="like-btn like-btn--sm like-btn--static">
                                    <i class="fa-solid fa-heart"></i> {{ p.like_count }}
                                </span>
                            {% endif %}
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% else %}
        <p class="empty-state">
            No public palettes yet.
            {% if current_user %}
                Make one of your palettes public to be featured here.
            {% else %}
                <a href="{{ url_for('login') }}">Sign in</a> to create palettes.
            {% endif %}
        </p>
    {% endif %}
{% endblock %}
