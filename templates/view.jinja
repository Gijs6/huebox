{% extends "base.jinja" %}

{% block title %}{{ palette.name }}{% endblock %}

{% block extra_headers %}
    {{ super() }}
    <script src="{{ url_for('static', filename='scripts/copy-text.js') }}" defer></script>
    <script src="{{ url_for('static', filename='scripts/view.js') }}" defer></script>
{% endblock %}

{% block main %}
    <div class="page-header">
        <h1 class="page-header__title">{{ palette.name }}</h1>
    </div>

    <div class="palette-view__meta">
        {% if palette.owner.avatar_url %}
            <img src="{{ palette.owner.avatar_url }}"
                 alt="{{ palette.owner.login }}"
                 class="palette-card__avatar">
        {% endif %}
        <span>by {{ palette.owner.login }}</span>
        <span class="palette-view__dot" aria-hidden="true">·</span>
        <span>{{ palette.colors | length }} color{{ 's' if palette.colors | length != 1 }}</span>
        <span class="palette-view__dot" aria-hidden="true">·</span>
        <span class="palette-view__visibility {% if palette.is_public %}palette-view__visibility--public{% else %}palette-view__visibility--private{% endif %}">
            <i class="fa-solid {% if palette.is_public %}fa-globe{% else %}fa-lock{% endif %}"
               aria-hidden="true"></i>
            {{ 'Public' if palette.is_public else 'Private' }}
        </span>
    </div>

    <div class="palette-view__strip">
        {% for color in palette.colors %}
            <button class="palette-view__swatch"
                    type="button"
                    style="--color: {{ color.hex_value }}"
                    data-hex="{{ color.hex_value }}"
                    title="Copy {{ color.hex_value }}">
                <span class="palette-view__swatch-info">
                    <span class="palette-view__swatch-hex">{{ color.hex_value }}</span>
                </span>
            </button>
        {% endfor %}
    </div>

    <div class="palette-view__actions">
        {% if current_user %}
            {% if current_user.id != palette.user_id %}
                <button type="button"
                        class="like-btn {% if user_liked %}like-btn--liked{% endif %}"
                        hx-post="{{ url_for('toggle_like', id=palette.id) }}"
                        hx-swap="none">
                    <i class="fa-solid fa-heart"></i>
                    {{ palette.like_count }}
                </button>
                <button type="button"
                        class="btn btn--ghost"
                        hx-post="{{ url_for('fork_palette', id=palette.id) }}"
                        hx-swap="none">Fork</button>
            {% else %}
                <span class="like-btn like-btn--static">
                    <i class="fa-solid fa-heart"></i>
                    {{ palette.like_count }}
                </span>
                <a href="{{ url_for('edit_palette', id=palette.id) }}"
                   class="btn btn--ghost">
                    <i class="fa-solid fa-pen"></i> Edit
                </a>
            {% endif %}
        {% else %}
            <span class="like-btn like-btn--static">
                <i class="fa-solid fa-heart"></i>
                {{ palette.like_count }}
            </span>
            <a href="{{ url_for('login') }}" class="btn btn--ghost">
                <i class="fa-brands fa-github"></i> Sign in to fork
            </a>
        {% endif %}

        <button type="button" class="btn btn--ghost" id="copyLinkBtn">
            <i class="fa-solid fa-link"></i> Copy link
        </button>
        <button type="button" class="btn btn--ghost" id="viewCssBtn">Copy CSS</button>
        <button type="button" class="btn btn--ghost" id="viewJsonBtn">Copy JSON</button>
    </div>

    {# djlint:off #}
    <script>
        const colors = {{ palette.colors | map(attribute='hex_value') | list | tojson }};
        const paletteName = {{ palette.name | tojson }};
</script>
    {# djlint:on #}
{% endblock %}
