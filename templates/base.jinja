{% extends "skeleton.jinja" %}

{% block content %}
    <div id="messages-container" class="messages-container" aria-live="polite">
        {% with messages = get_flashed_messages(with_categories=true) %}
            {% for category, message in messages %}
                <div class="toast toast--{{ category }} toast--visible" data-flash>
                    {% if category == 'success' %}
                        <i class="fa-solid fa-circle-check" aria-hidden="true"></i>
                    {% elif category == 'error' %}
                        <i class="fa-solid fa-circle-xmark" aria-hidden="true"></i>
                    {% elif category == 'info' %}
                        <i class="fa-solid fa-circle-info" aria-hidden="true"></i>
                    {% endif %}
                    {{ message }}
                </div>
            {% endfor %}
        {% endwith %}
    </div>

    <script>
        (function () {
            const container = document.getElementById("messages-container");
            container.querySelectorAll("[data-flash]").forEach(el => {
                setTimeout(() => {
                    el.classList.remove("toast--visible");
                    setTimeout(() => el.remove(), 200);
                }, 4000);
            });
            window.showToast = function (msg, type) {
                const el = document.createElement("div");
                el.className = "toast" + (type ? " toast--" + type : "");
                el.textContent = msg;
                container.appendChild(el);
                requestAnimationFrame(() => el.classList.add("toast--visible"));
                setTimeout(() => {
                    el.classList.remove("toast--visible");
                    setTimeout(() => el.remove(), 200);
                }, 1600);
            };
        })();
    </script>

    <header class="site-header">
        <a href="{{ url_for('index') }}" class="site-header__logo">Huebox</a>

        <nav class="site-header__nav">
            <a href="{{ url_for('explore') }}" class="site-header__link">Explore</a>

            {% if current_user %}
                <a href="{{ url_for('list') }}" class="site-header__link">Palettes</a>
                <a href="{{ url_for('new') }}" class="site-header__link">New</a>
                <div class="site-header__user-menu">
                    <button class="site-header__user" type="button">
                        {% if current_user.avatar_url %}
                            <img src="{{ current_user.avatar_url }}"
                                 alt="{{ current_user.login }}"
                                 class="site-header__avatar">
                        {% endif %}
                        {{ current_user.login }}
                        <i class="fa-solid fa-chevron-down site-header__user-chevron"></i>
                    </button>
                    <div class="site-header__dropdown">
                        <button type="button"
                                class="site-header__dropdown-item"
                                hx-post="{{ url_for('logout') }}"
                                hx-swap="none">
                            <i class="fa-solid fa-right-from-bracket"></i> Sign out
                        </button>
                    </div>
                </div>
            {% else %}
                <a href="{{ url_for('login') }}" class="btn">
                    <i class="fa-brands fa-github"></i> Sign in
                </a>
            {% endif %}
        </nav>
    </header>

    <main class="page">
        {% block main %}{% endblock %}
    </main>
{% endblock %}
