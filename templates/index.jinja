{% extends "skeleton.jinja" %}

{% block title %}Huebox{% endblock %}

{% block content %}
    <div class="splash">
        <canvas class="splash__canvas" id="splashCanvas"></canvas>

        <div class="splash__center">
            <h1 class="splash__title">Huebox</h1>
            <p class="splash__sub">A minimal color palette manager.</p>
            <div class="splash__actions">
                {% if current_user %}
                    <a href="{{ url_for('list') }}" class="btn btn--lg">My palettes →</a>
                {% else %}
                    <a href="{{ url_for('login') }}" class="btn btn--lg">
                        <i class="fa-brands fa-github"></i> Sign in with GitHub
                    </a>
                {% endif %}
                <a href="{{ url_for('explore') }}" class="btn btn--lg btn--ghost">Explore</a>
            </div>
        </div>
    </div>

    <script>
        const canvas = document.getElementById("splashCanvas");
        const ctx = canvas.getContext("2d");
        let chips = [];
        const mouse = { x: -9999, y: -9999 };

        function makeChip() {
            const r = Math.floor(Math.random() * 256);
            const g = Math.floor(Math.random() * 256);
            const b = Math.floor(Math.random() * 256);
            const color = `rgb(${r},${g},${b})`;
            const angle = Math.random() * Math.PI * 2;
            const spd = 0.25 + Math.random() * 0.55;
            return {
                x: Math.random() * canvas.width,
                y: Math.random() * canvas.height,
                vx: Math.cos(angle) * spd,
                vy: Math.sin(angle) * spd,
                rot: Math.random() * Math.PI * 2,
                rotSpd: (Math.random() - 0.5) * 0.007,
                color,
                w: 22 + Math.random() * 56,
                h: 10 + Math.random() * 28,
                alpha: 0.2 + Math.random() * 0.65,
                wander: Math.random() * Math.PI * 2,
                wanderSpd: (Math.random() - 0.5) * 0.018,
            };
        }

        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }

        function init() {
            resize();
            chips = Array.from({ length: 70 }, makeChip);
        }

        function frame() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);

            for (const p of chips) {
                // Gentle wandering drift
                p.wander += p.wanderSpd + (Math.random() - 0.5) * 0.004;
                p.vx += Math.cos(p.wander) * 0.012;
                p.vy += Math.sin(p.wander) * 0.012;

                // Swirl toward mouse
                if (mouse.x > -999) {
                    const dx = mouse.x - p.x;
                    const dy = mouse.y - p.y;
                    const dist = Math.hypot(dx, dy);
                    if (dist < 500 && dist > 1) {
                        const t = 1 - dist / 500;
                        p.vx += (dx / dist) * 0.18 * t;
                        p.vy += (dy / dist) * 0.18 * t;
                        p.vx += (-dy / dist) * 0.10 * t;
                        p.vy += (dx / dist) * 0.10 * t;
                    }
                }

                // Speed cap + drag
                const spd = Math.hypot(p.vx, p.vy);
                if (spd > 4.0) { p.vx = p.vx / spd * 4.0; p.vy = p.vy / spd * 4.0; }
                p.vx *= 0.992;
                p.vy *= 0.992;

                p.x += p.vx;
                p.y += p.vy;
                p.rot += p.rotSpd;

                // Wrap edges
                const pad = Math.max(p.w, p.h);
                if (p.x < -pad) p.x = canvas.width + pad;
                else if (p.x > canvas.width + pad) p.x = -pad;
                if (p.y < -pad) p.y = canvas.height + pad;
                else if (p.y > canvas.height + pad) p.y = -pad;

                ctx.save();
                ctx.globalAlpha = p.alpha;
                ctx.translate(p.x, p.y);
                ctx.rotate(p.rot);
                ctx.fillStyle = p.color;
                ctx.fillRect(-p.w / 2, -p.h / 2, p.w, p.h);
                ctx.restore();
            }

            requestAnimationFrame(frame);
        }

        window.addEventListener("mousemove", e => { mouse.x = e.clientX; mouse.y = e.clientY; });
        window.addEventListener("mouseleave", () => { mouse.x = -9999; mouse.y = -9999; });
        window.addEventListener("click", e => {
            for (const p of chips) {
                const dx = p.x - e.clientX;
                const dy = p.y - e.clientY;
                const dist = Math.hypot(dx, dy);
                if (dist < 380 && dist > 1) {
                    const force = 7 * (1 - dist / 380);
                    p.vx += (dx / dist) * force;
                    p.vy += (dy / dist) * force;
                    p.rotSpd = (Math.random() - 0.5) * 0.18;
                }
            }
        });
        window.addEventListener("resize", () => {
            resize();
            for (const p of chips) {
                p.x = Math.random() * canvas.width;
                p.y = Math.random() * canvas.height;
            }
        });

        init();
        frame();
    </script>
{% endblock %}
