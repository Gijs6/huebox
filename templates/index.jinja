{% extends "skeleton.jinja" %}

{% block title %}Huebox{% endblock %}

{% block extra_headers %}<script src="{{ url_for('static', filename='scripts/splash.js') }}" defer></script>{% endblock %}

{% block content %}
    <div class="splash">
        <canvas class="splash__canvas" id="splashCanvas"></canvas>

        <div class="splash__center">
            <h1 class="splash__title">
                <span class="splash__title-letter">H</span><span class="splash__title-letter">u</span><span class="splash__title-letter">e</span><span class="splash__title-letter">b</span><span class="splash__title-letter">o</span><span class="splash__title-letter">x</span>
            </h1>
            <div class="splash__actions">
                {% if current_user %}
                    <a href="{{ url_for('list') }}" class="btn btn--lg">My palettes →</a>
                {% else %}
                    <a href="{{ url_for('login') }}" class="btn btn--lg">
                        <i class="fa-brands fa-github"></i> Sign in with GitHub
                    </a>
                {% endif %}
                <a href="{{ url_for('explore') }}" class="btn btn--lg btn--ghost">Explore</a>
            </div>
        </div>
    </div>

{% endblock %}
